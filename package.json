{
  "name": "git-branch-agent",
  "version": "1.0.0",
  "description": "Desktop app to create GitHub branches from Jira tickets and log work time",
  "main": "main.js",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "create-branch": "node scripts/create-branch.js",
    "create-mid-branch": "node scripts/create-mid-branch.js",
    "log-time": "node scripts/log-time.js",
    "create-jira-ticket": "node scripts/create-jira-ticket.js",
    "get-cost-centers": "node scripts/get-cost-centers.js",
    "build": "electron-builder build --win --publish never",
    "build:all": "electron-builder build --win --mac --linux --publish never",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.gitbranchagent.app",
    "productName": "Git Branch Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^17.4.11",
    "electron-builder": "^22.14.13"
  }
}
